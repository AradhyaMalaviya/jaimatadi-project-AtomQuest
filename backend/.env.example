NODE_ENV=development
PORT=3001
DATABASE_URL="postgresql://atomquest:atomquest@localhost:5432/atomquest?schema=public"
JWT_ACCESS_SECRET="replace-with-at-least-32-characters-access-secret"
JWT_REFRESH_SECRET="replace-with-at-least-32-characters-refresh-secret"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ALLOWED_ORIGINS="http://localhost:5173"

# Microsoft Entra ID SSO configuration.
# Leave these blank for local mock-user login.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI="http://localhost:3001/api/auth/callback/sso"
