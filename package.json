{
  "name": "atomquest-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "build": "npm run build --prefix backend && npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "test": "npm test --prefix backend",
    "prisma:validate": "npm run prisma:validate --prefix backend",
    "db:push": "npm run db:push --prefix backend",
    "db:seed": "npm run db:seed --prefix backend",
    "install": "npm install --prefix frontend && npm install --prefix backend"
  }
}
